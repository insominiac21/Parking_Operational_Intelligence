{
  "rewrites": [
    {
      "source": "/health/semantic",
      "destination": "https://parking-operational-intelligence-backend.onrender.com/health"
    },
    {
      "source": "/health/primary",
      "destination": "https://parking-operational-intelligence.onrender.com/health"
    },
    {
      "source": "/api/search",
      "destination": "https://parking-operational-intelligence-backend.onrender.com/api/search"
    },
    {
      "source": "/api/:path*",
      "destination": "https://parking-operational-intelligence.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
